{{ 'custom-shooting-shirt.css' | asset_url | stylesheet_tag }}
{{ 'custom-travel-gear.css' | asset_url | stylesheet_tag }}
{{ 'custom-origin-fleece.css' | asset_url | stylesheet_tag }}
<script src="{{ 'custom-origin-fleece.js' | asset_url }}" defer></script>

{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image = product.featured_image | default: product.images.first
  assign contact_link = section.settings.contact_url | default: '/pages/contact'
  assign min_pieces = section.settings.min_pieces | default: 6
  assign unit_price_display = current_variant.price | money
  if min_pieces < 6
    assign min_pieces = 6
  endif

  assign title_downcase = product.title | downcase
  assign garment_label = 'Origin Fleece Hoodie'
  assign product_style = 'Origin'
  assign garment_type = 'Hoodie'
  assign requested_unit_price_cents = 6000
  assign intro_copy = section.settings.hoodie_intro_copy
  if title_downcase contains 'jogger'
    assign garment_label = 'Origin Fleece Jogger'
    assign garment_type = 'Jogger'
    assign requested_unit_price_cents = 5000
    assign intro_copy = section.settings.jogger_intro_copy
  endif

  assign requested_unit_price_display = requested_unit_price_cents | money
  assign display_price = requested_unit_price_display | append: ' each'
  assign base_colors = 'Black:#111111,Heather Grey:#C8C8C2,Charcoal:#676767,Team Red:#C63737,Team Navy:#203A72,Team Royal:#4056B4' | split: ','
  assign artwork_colors = 'Black:#111111,White:#FFFFFF,Grey:#A7ADB3,Maroon:#6F263D,Team Red:#C63737,Red:#D73B32,Bright Pink:#B04A8B,Light Pink:#B6849A,Purple:#52426F,Team Navy:#203A72,Team Royal:#4056B4,Atomic Blue:#4F8FB4,Bright Blue:#78AFCF,Forest Green:#4F6E54,Kelly Green:#3F7B4B,Bright Green:#6B8E45,Texas Orange:#A35F3E,Bright Orange:#B54F35,Orange:#B45A3F,Gold Yellow:#B08D2F,Yellow:#B7A82F,Vegas Gold:#78704E,Brown:#6A5B52' | split: ','
  assign spec_points = '70% polyester / 30% cotton.,8.8oz fleece.,Tagless.,Spandex ribbing.' | split: ','
%}

<section
  class="custom-origin-fleece-section travel-gear-section shooting-shirt-section"
  data-section-id="{{ section.id }}"
  data-min-pieces="{{ min_pieces }}"
  data-unit-price-cents="{{ current_variant.price }}"
  data-expected-unit-price-cents="{{ requested_unit_price_cents }}"
  data-expected-unit-price-label="{{ requested_unit_price_display }}"
>
  <div class="shooting-shirt-section__utility-bar" aria-label="Origin fleece order details">
    <div class="shooting-shirt-section__utility-item">
      <span class="shooting-shirt-section__utility-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M12 3.75c4 0 7.25 3.25 7.25 7.25 0 5.4-7.25 9.25-7.25 9.25S4.75 16.4 4.75 11c0-4 3.25-7.25 7.25-7.25Z" stroke="currentColor" stroke-width="1.7"/>
          <path d="m8.25 8.25 7.5 7.5M15.75 8.25l-7.5 7.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
        </svg>
      </span>
      <div class="shooting-shirt-section__utility-copy">
        <p class="shooting-shirt-section__utility-title">No Returns</p>
        <p class="shooting-shirt-section__utility-text">All custom fleece orders are final</p>
      </div>
    </div>
    <div class="shooting-shirt-section__utility-item">
      <span class="shooting-shirt-section__utility-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M12 4.5 18.5 8v8L12 19.5 5.5 16V8L12 4.5Z" stroke="currentColor" stroke-width="1.7"/>
          <path d="M5.5 8 12 12l6.5-4M12 12v7.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
        </svg>
      </span>
      <div class="shooting-shirt-section__utility-copy">
        <p class="shooting-shirt-section__utility-title">Minimum Order</p>
        <p class="shooting-shirt-section__utility-text">{{ section.settings.minimum_order }}</p>
      </div>
    </div>
    <a class="shooting-shirt-section__utility-item shooting-shirt-section__utility-item--link" href="{{ contact_link }}">
      <span class="shooting-shirt-section__utility-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M7.5 17.5 4 20V6.75A2.75 2.75 0 0 1 6.75 4h10.5A2.75 2.75 0 0 1 20 6.75v7.5A2.75 2.75 0 0 1 17.25 17H7.5Z" stroke="currentColor" stroke-width="1.7"/>
          <path d="M8.25 9.25h7.5M8.25 12.5h5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
        </svg>
      </span>
      <div class="shooting-shirt-section__utility-copy">
        <p class="shooting-shirt-section__utility-title">Need Help?</p>
        <p class="shooting-shirt-section__utility-text">Contact our team</p>
      </div>
    </a>
  </div>

  <div class="shooting-shirt-section__inner">
    <form
      class="shooting-shirt-section__order-canvas travel-gear-section__order-canvas"
      data-origin-fleece-form
      action="{{ routes.cart_add_url }}"
      method="post"
      enctype="multipart/form-data"
      accept-charset="UTF-8"
      novalidate
    >
      <input type="hidden" name="id" value="{{ current_variant.id }}">
      <input type="hidden" name="quantity" value="1" data-cart-quantity>
      <input type="hidden" name="properties[Requested Unit Price]" value="{{ display_price }}">
      <input type="hidden" name="properties[Unit Price]" value="{{ unit_price_display }}">
      <input type="hidden" name="properties[Calculated Order Total]" value="$0.00" data-calculated-total-property>
      <input type="hidden" name="properties[Displayed Total Context]" value="Before tax and discounts">
      <input type="hidden" name="properties[Checkout Billing Mode]" value="Shopify checkout quantity synced to total pieces">
      <input type="hidden" name="properties[Product Style]" value="{{ product_style }}">
      <input type="hidden" name="properties[Product Type]" value="Travel Gear / Fleece">
      <input type="hidden" name="properties[Garment Type]" value="{{ garment_label }}">
      <input type="hidden" name="properties[Base/Garment Color]" value="#111111 (Black)" data-color-property="Base">
      <input type="hidden" name="properties[Artwork Color]" value="#FFFFFF (White)" data-color-property="Artwork">
      <input type="hidden" name="properties[Size Breakdown]" value="" data-size-breakdown-property>
      <input type="hidden" name="properties[Total Pieces]" value="0" data-total-pieces-property>
      <input type="hidden" name="properties[Company]" value="Crossover Culture">
      <input type="hidden" name="properties[Order Flow]" value="Origin Fleece Customizer">
      <input type="hidden" name="properties[Source Product]" value="{{ product.title }}">

      <div class="shooting-shirt-section__message shooting-shirt-section__message--error" data-form-message="error" role="alert" hidden></div>

      <div class="shooting-shirt-section__gallery-column">
        <div class="shooting-shirt-section__gallery">
          <div class="shooting-shirt-section__thumbnails" role="tablist" aria-label="Product images">
            {% for image in product.images %}
              <button
                type="button"
                class="shooting-shirt-section__thumbnail{% if image.id == featured_image.id %} is-active{% endif %}"
                data-gallery-thumb
                data-image-src="{{ image | image_url: width: 1800 }}"
                data-image-alt="{{ image.alt | default: product.title | escape }}"
                aria-label="View image {{ forloop.index }}"
                aria-selected="{% if image.id == featured_image.id %}true{% else %}false{% endif %}"
              >
                <img
                  src="{{ image | image_url: width: 220 }}"
                  alt="{{ image.alt | default: product.title | escape }}"
                  loading="lazy"
                  width="90"
                  height="108"
                >
              </button>
            {% endfor %}
          </div>

          <div class="shooting-shirt-section__main-image-shell">
            {% if featured_image %}
              <img
                class="shooting-shirt-section__main-image"
                data-main-image
                src="{{ featured_image | image_url: width: 1800 }}"
                alt="{{ featured_image.alt | default: product.title | escape }}"
                loading="eager"
                width="{{ featured_image.width }}"
                height="{{ featured_image.height }}"
              >
            {% else %}
              <div class="shooting-shirt-section__main-image shooting-shirt-section__main-image--fallback" aria-hidden="true">
                <svg class="shooting-shirt-section__fallback-svg" viewBox="0 0 240 240" fill="none">
                  <rect x="40" y="48" width="160" height="144" stroke="currentColor" stroke-width="8"/>
                  <path d="M64 168l40-44 28 28 24-20 20 36" stroke="currentColor" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="92" cy="92" r="14" fill="currentColor"/>
                </svg>
              </div>
            {% endif %}
          </div>
        </div>
        <p class="shooting-shirt-section__gallery-note">Use the product gallery to show front, back, and detail views before the customer submits the order.</p>
      </div>

      <div class="shooting-shirt-section__meta-column">
        <div class="shooting-shirt-section__product-meta">
          <p class="shooting-shirt-section__eyebrow">Premium Team Fleece Ordering</p>
          <h1 class="shooting-shirt-section__title">{{ product.title }}</h1>
          <p class="shooting-shirt-section__price">{{ display_price }}</p>
          {% if current_variant.price != requested_unit_price_cents %}
            <p class="custom-origin-fleece-section__pricing-warning">Shopify variant price is currently {{ unit_price_display }}. Set this product variant to {{ requested_unit_price_display }} before taking checkout orders.</p>
          {% endif %}
          <p class="shooting-shirt-section__intro">{{ intro_copy }}</p>
          <ul class="shooting-shirt-section__feature-list">
            {% for point in spec_points %}
              <li>{{ point }}</li>
            {% endfor %}
            <li>Choose one stock base color, one artwork color, and upload one vector artwork file.</li>
          </ul>
        </div>

        <div class="shooting-shirt-section__summary-bar custom-origin-fleece-section__price-grid">
          <div class="shooting-shirt-section__summary-chip">
            <span class="shooting-shirt-section__summary-label">Requested Price</span>
            <span class="shooting-shirt-section__summary-value">{{ requested_unit_price_display }} each</span>
          </div>
          <div class="shooting-shirt-section__summary-chip">
            <span class="shooting-shirt-section__summary-label">Shopify Price</span>
            <span class="shooting-shirt-section__summary-value">{{ unit_price_display }} each</span>
          </div>
          <div class="shooting-shirt-section__summary-chip">
            <span class="shooting-shirt-section__summary-label">Style</span>
            <span class="shooting-shirt-section__summary-value">{{ product_style }}</span>
          </div>
          <div class="shooting-shirt-section__summary-chip">
            <span class="shooting-shirt-section__summary-label">Fit</span>
            <span class="shooting-shirt-section__summary-value">Unisex Adult</span>
          </div>
          <div class="shooting-shirt-section__summary-chip">
            <span class="shooting-shirt-section__summary-label">Minimum</span>
            <span class="shooting-shirt-section__summary-value">{{ min_pieces }} Pieces</span>
          </div>
          <div class="shooting-shirt-section__summary-chip">
            <span class="shooting-shirt-section__summary-label">Estimated Total</span>
            <span class="shooting-shirt-section__summary-value" data-summary-order-total>$0.00</span>
          </div>
        </div>
      </div>

      <section class="shooting-shirt-section__panel shooting-shirt-section__panel--colors">
        <div class="shooting-shirt-section__field-header">
          <span class="shooting-shirt-section__field-label">1. Colors</span>
          <button type="button" class="shooting-shirt-section__reset-link" data-reset-colors>Reset to default</button>
        </div>

        <div class="shooting-shirt-section__color-studio">
          <div class="shooting-shirt-section__color-topline">
            <div class="shooting-shirt-section__color-targets" role="tablist" aria-label="Color application">
              <button type="button" class="shooting-shirt-section__color-target is-active" data-color-target-button data-color-target="Base" aria-pressed="true">Base Color</button>
              <button type="button" class="shooting-shirt-section__color-target" data-color-target-button data-color-target="Artwork" aria-pressed="false">Artwork Color</button>
            </div>
            <p class="shooting-shirt-section__color-caption" data-active-color-display>#111111 (Black)</p>
          </div>

          <div class="shooting-shirt-section__color-layout">
            <label class="shooting-shirt-section__wheel-shell" aria-label="Choose Origin Fleece color">
              <span class="shooting-shirt-section__wheel-visual"></span>
              <input type="color" class="shooting-shirt-section__wheel-input" value="#111111" data-color-picker>
            </label>

            <div class="shooting-shirt-section__palette-area custom-origin-fleece-section__palette-area">
              <p class="shooting-shirt-section__color-apply" data-color-apply-copy>Applies to the main fleece body.</p>

              <p class="shooting-shirt-section__swatch-group-label">Select any production color using the wheel or enter a HEX value.</p>

              <div class="shooting-shirt-section__hex-shell">
                <label class="shooting-shirt-section__field-label shooting-shirt-section__field-label--small" for="OriginFleeceColorHex-{{ section.id }}">Custom HEX</label>
                <div class="shooting-shirt-section__hex-row">
                  <span class="shooting-shirt-section__hex-preview" data-color-preview aria-hidden="true"></span>
                  <input
                    id="OriginFleeceColorHex-{{ section.id }}"
                    class="shooting-shirt-section__text-input"
                    type="text"
                    maxlength="7"
                    value="#111111"
                    autocomplete="off"
                    inputmode="text"
                    data-color-hex
                  >
                </div>
              </div>
            </div>
          </div>

          <div class="shooting-shirt-section__color-summary">
            <div class="shooting-shirt-section__color-summary-item" data-color-summary="Base">
              <span class="shooting-shirt-section__color-summary-label">Base Color</span>
              <span class="shooting-shirt-section__color-summary-value">#111111 (Black)</span>
            </div>
            <div class="shooting-shirt-section__color-summary-item" data-color-summary="Artwork">
              <span class="shooting-shirt-section__color-summary-label">Artwork Color</span>
              <span class="shooting-shirt-section__color-summary-value">#FFFFFF (White)</span>
            </div>
          </div>
        </div>
      </section>

      <section class="shooting-shirt-section__panel shooting-shirt-section__panel--sizes">
        <div class="shooting-shirt-section__field-header">
          <span class="shooting-shirt-section__field-label">2. Size Breakdown</span>
          <span class="shooting-shirt-section__field-meta">Minimum {{ min_pieces }} total pieces</span>
        </div>

        <div class="shooting-shirt-section__sizes-grid custom-origin-fleece-section__sizes-grid">
          <div class="shooting-shirt-section__sizes-panel">
            <div class="shooting-shirt-section__sizes-panel-head">
              <span class="shooting-shirt-section__sizes-title">Unisex Adult</span>
              <span class="shooting-shirt-section__sizes-note">XS-3XL</span>
            </div>
            <div class="shooting-shirt-section__sizes-list">
              {% assign adult_sizes = 'XS,S,M,L,XL,2XL,3XL' | split: ',' %}
              {% for size in adult_sizes %}
                <label class="shooting-shirt-section__size-row">
                  <span class="shooting-shirt-section__size-name">{{ size }}</span>
                  <input
                    class="shooting-shirt-section__quantity-input"
                    type="number"
                    min="0"
                    max="99"
                    placeholder="0"
                    inputmode="numeric"
                    data-size-quantity
                    data-size-label="Unisex Adult {{ size }}"
                  >
                </label>
              {% endfor %}
            </div>
          </div>
        </div>
      </section>

      <section class="shooting-shirt-section__panel shooting-shirt-section__panel--upload">
        <div class="shooting-shirt-section__field-header">
          <span class="shooting-shirt-section__field-label">3. Artwork Upload</span>
          <span class="shooting-shirt-section__field-meta">SVG, AI, EPS only</span>
        </div>
        <div class="shooting-shirt-section__upload-copy">
          <p class="shooting-shirt-section__upload-headline">One production-ready vector file for this fleece order.</p>
          <p class="shooting-shirt-section__upload-note">This file stays attached to the order so the production team can review the exact art before checkout fulfillment.</p>
        </div>
        <input
          class="shooting-shirt-section__file-input"
          type="file"
          name="properties[Artwork Upload]"
          accept=".svg,.ai,.eps"
          data-vector-upload
          required
        >
        <p class="shooting-shirt-section__upload-filename" data-upload-name>No file selected</p>
      </section>

      <section class="shooting-shirt-section__panel shooting-shirt-section__panel--notes">
        <div class="shooting-shirt-section__field-header">
          <label class="shooting-shirt-section__field-label" for="OrderNotes-{{ section.id }}">4. Order Notes</label>
          <span class="shooting-shirt-section__field-meta">Optional</span>
        </div>
        <textarea
          id="OrderNotes-{{ section.id }}"
          class="shooting-shirt-section__textarea"
          name="properties[Notes]"
          rows="6"
          placeholder="Add placement notes, artwork notes, or special instructions here."
        ></textarea>
      </section>

      <section class="shooting-shirt-section__panel shooting-shirt-section__panel--summary">
        <div class="shooting-shirt-section__field-header">
          <span class="shooting-shirt-section__field-label">Order Summary</span>
          <span class="shooting-shirt-section__field-meta">Saved with the order</span>
        </div>

        <div class="shooting-shirt-section__order-summary travel-gear-section__order-summary custom-origin-fleece-section__order-summary">
          <div class="shooting-shirt-section__order-summary-item">
            <span class="shooting-shirt-section__order-summary-label">Garment</span>
            <span class="shooting-shirt-section__order-summary-value">{{ garment_label }}</span>
          </div>
          <div class="shooting-shirt-section__order-summary-item">
            <span class="shooting-shirt-section__order-summary-label">Base Color</span>
            <span class="shooting-shirt-section__order-summary-value" data-summary-color="Base">#111111 (Black)</span>
          </div>
          <div class="shooting-shirt-section__order-summary-item">
            <span class="shooting-shirt-section__order-summary-label">Artwork Color</span>
            <span class="shooting-shirt-section__order-summary-value" data-summary-color="Artwork">#FFFFFF (White)</span>
          </div>
          <div class="shooting-shirt-section__order-summary-item">
            <span class="shooting-shirt-section__order-summary-label">Total Pieces</span>
            <span class="shooting-shirt-section__order-summary-value" data-summary-total-pieces>0 pieces</span>
          </div>
          <div class="shooting-shirt-section__order-summary-item">
            <span class="shooting-shirt-section__order-summary-label">Size Breakdown</span>
            <span class="shooting-shirt-section__order-summary-value" data-summary-size-breakdown>Not entered yet</span>
          </div>
          <div class="shooting-shirt-section__order-summary-item">
            <span class="shooting-shirt-section__order-summary-label">Upload Status</span>
            <span class="shooting-shirt-section__order-summary-value" data-summary-upload>No file selected</span>
          </div>
        </div>
      </section>

      <div class="shooting-shirt-section__cta-section">
        <div class="shooting-shirt-section__cta-group">
          <button type="submit" class="shooting-shirt-section__cta shooting-shirt-section__cta--primary" data-add-to-cart data-submitting-label="Adding Fleece Order...">
            Add {{ garment_type }} Order To Cart
          </button>
          <a class="shooting-shirt-section__cta-link" href="/pages/contact?type=quote">Request Team Quote</a>
        </div>
      </div>

      <p class="shooting-shirt-section__rules">Minimum order: {{ min_pieces }} pieces. Base color, artwork color, size breakdown, notes, pricing details, and vector artwork upload are submitted with the order. Shopify checkout quantity syncs to total ordered pieces.</p>
    </form>
  </div>
</section>

{% schema %}
{
  "name": "Origin Fleece Order",
  "tag": "section",
  "class": "custom-origin-fleece-section",
  "settings": [
    { "type": "text", "id": "minimum_order", "label": "Minimum Order Text", "default": "6 pieces per order" },
    { "type": "url", "id": "contact_url", "label": "Contact Page URL" },
    { "type": "number", "id": "min_pieces", "label": "Minimum Pieces", "default": 6 },
    { "type": "textarea", "id": "hoodie_intro_copy", "label": "Hoodie Intro Copy", "default": "Build your Origin Fleece Hoodie order with one stock base color, one artwork color, a full XS-3XL size breakdown, and one vector artwork upload in a production-ready form." },
    { "type": "textarea", "id": "jogger_intro_copy", "label": "Jogger Intro Copy", "default": "Build your Origin Fleece Jogger order with one stock base color, one artwork color, a full XS-3XL size breakdown, and one vector artwork upload in a production-ready form." }
  ],
  "presets": [{ "name": "Origin Fleece Order" }]
}
{% endschema %}
