{{ 'custom-shooting-shirt.css' | asset_url | stylesheet_tag }}
{{ 'custom-practice-shorts.css' | asset_url | stylesheet_tag }}
<script src="{{ 'custom-practice-shorts.js' | asset_url }}" defer></script>

{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image = product.featured_image | default: product.images.first
  assign contact_link = section.settings.contact_url | default: '/pages/contact'
  assign min_pieces = section.settings.min_pieces | default: 6
  if min_pieces < 6
    assign min_pieces = 6
  endif

  assign product_style = 'Enlisted'
  assign garment_label = 'Practice Shorts'
  assign display_price = 'Mens / Womens $40.00 each | Youth $30.00 each'
  assign short_colors = 'White:#FFFFFF,Black:#111111,Iron Grey:#6E7175,Team Navy:#203A72,Team Royal:#2454C6,Forest Green:#355B3E,Team Red:#BF2B2B,Maroon:#6F263D,Gold Yellow:#B89641' | split: ','
  assign artwork_colors = 'Black:#111111,White:#FFFFFF,Silver Grey:#A7ADB3,Team Navy:#203A72,Team Royal:#2454C6,Forest Green:#355B3E,Team Red:#BF2B2B,Maroon:#6F263D,Gold Yellow:#B89641,Orange:#CB6A2D' | split: ','
%}

<section
  class="custom-practice-shorts-section shooting-shirt-section"
  data-section-id="{{ section.id }}"
  data-min-pieces="{{ min_pieces }}"
>
  <div class="shooting-shirt-section__utility-bar" aria-label="Practice shorts order details">
    <div class="shooting-shirt-section__utility-item">
      <span class="shooting-shirt-section__utility-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M4 7.5 8.5 3H20v11.5L15.5 19H4V7.5Z" stroke="currentColor" stroke-width="1.7"/>
          <path d="m8.5 3 7 7M6.5 10.5h4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
        </svg>
      </span>
      <div class="shooting-shirt-section__utility-copy">
        <p class="shooting-shirt-section__utility-title">Enlisted Practice Shorts</p>
        <p class="shooting-shirt-section__utility-text">{{ section.settings.utility_bar_delivery }}</p>
      </div>
    </div>
    <div class="shooting-shirt-section__utility-item">
      <span class="shooting-shirt-section__utility-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M12 3.75c4 0 7.25 3.25 7.25 7.25 0 5.4-7.25 9.25-7.25 9.25S4.75 16.4 4.75 11c0-4 3.25-7.25 7.25-7.25Z" stroke="currentColor" stroke-width="1.7"/>
          <path d="m8.25 8.25 7.5 7.5M15.75 8.25l-7.5 7.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
        </svg>
      </span>
      <div class="shooting-shirt-section__utility-copy">
        <p class="shooting-shirt-section__utility-title">No Returns</p>
        <p class="shooting-shirt-section__utility-text">All custom orders are final</p>
      </div>
    </div>
    <div class="shooting-shirt-section__utility-item">
      <span class="shooting-shirt-section__utility-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M12 4.5 18.5 8v8L12 19.5 5.5 16V8L12 4.5Z" stroke="currentColor" stroke-width="1.7"/>
          <path d="M5.5 8 12 12l6.5-4M12 12v7.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
        </svg>
      </span>
      <div class="shooting-shirt-section__utility-copy">
        <p class="shooting-shirt-section__utility-title">Minimum Order</p>
        <p class="shooting-shirt-section__utility-text">{{ section.settings.minimum_order }}</p>
      </div>
    </div>
    <a class="shooting-shirt-section__utility-item shooting-shirt-section__utility-item--link" href="{{ contact_link }}">
      <span class="shooting-shirt-section__utility-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M7.5 17.5 4 20V6.75A2.75 2.75 0 0 1 6.75 4h10.5A2.75 2.75 0 0 1 20 6.75v7.5A2.75 2.75 0 0 1 17.25 17H7.5Z" stroke="currentColor" stroke-width="1.7"/>
          <path d="M8.25 9.25h7.5M8.25 12.5h5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
        </svg>
      </span>
      <div class="shooting-shirt-section__utility-copy">
        <p class="shooting-shirt-section__utility-title">Need Help?</p>
        <p class="shooting-shirt-section__utility-text">Contact our team</p>
      </div>
    </a>
  </div>

  <div class="shooting-shirt-section__inner">
    <form
      class="shooting-shirt-section__order-canvas"
      data-practice-shorts-form
      action="{{ routes.cart_add_url }}"
      method="post"
      enctype="multipart/form-data"
      accept-charset="UTF-8"
      novalidate
    >
      <input type="hidden" name="id" value="{{ current_variant.id }}">
      <input type="hidden" name="quantity" value="1">
      <input type="hidden" name="properties[Requested Unit Price]" value="{{ display_price }}">
      <input type="hidden" name="properties[Product Style]" value="{{ product_style }}">
      <input type="hidden" name="properties[Garment Type]" value="{{ garment_label }}">
      <input type="hidden" name="properties[Short Color]" value="#111111 (Black)" data-color-property="Base">
      <input type="hidden" name="properties[Artwork / Decoration Color]" value="#FFFFFF (White)" data-color-property="Artwork">
      <input type="hidden" name="properties[Size Breakdown]" value="" data-size-breakdown-property>
      <input type="hidden" name="properties[Total Pieces]" value="0" data-total-pieces-property>
      <input type="hidden" name="properties[_Company]" value="Crossover Culture">
      <input type="hidden" name="properties[_Order Flow]" value="Practice Shorts Customizer">
      <input type="hidden" name="properties[_Source Product]" value="{{ product.title }}">

      <div class="shooting-shirt-section__message shooting-shirt-section__message--error" data-form-message="error" role="alert" hidden></div>

      <div class="shooting-shirt-section__gallery-column">
        <div class="shooting-shirt-section__gallery">
          <div class="shooting-shirt-section__thumbnails" role="tablist" aria-label="Product images">
            {% for image in product.images %}
              <button
                type="button"
                class="shooting-shirt-section__thumbnail{% if image.id == featured_image.id %} is-active{% endif %}"
                data-gallery-thumb
                data-image-src="{{ image | image_url: width: 1800 }}"
                data-image-alt="{{ image.alt | default: product.title | escape }}"
                aria-label="View image {{ forloop.index }}"
                aria-selected="{% if image.id == featured_image.id %}true{% else %}false{% endif %}"
              >
                <img
                  src="{{ image | image_url: width: 220 }}"
                  alt="{{ image.alt | default: product.title | escape }}"
                  loading="lazy"
                  width="90"
                  height="108"
                >
              </button>
            {% endfor %}
          </div>

          <div class="shooting-shirt-section__main-image-shell">
            {% if featured_image %}
              <img
                class="shooting-shirt-section__main-image"
                data-main-image
                src="{{ featured_image | image_url: width: 1800 }}"
                alt="{{ featured_image.alt | default: product.title | escape }}"
                loading="eager"
                width="{{ featured_image.width }}"
                height="{{ featured_image.height }}"
              >
            {% else %}
              <div class="shooting-shirt-section__main-image shooting-shirt-section__main-image--fallback" aria-hidden="true">
                <svg class="shooting-shirt-section__fallback-svg" viewBox="0 0 240 240" fill="none">
                  <rect x="40" y="48" width="160" height="144" stroke="currentColor" stroke-width="8"/>
                  <path d="M64 168l40-44 28 28 24-20 20 36" stroke="currentColor" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="92" cy="92" r="14" fill="currentColor"/>
                </svg>
              </div>
            {% endif %}
          </div>
        </div>
        <p class="shooting-shirt-section__gallery-note">Use the product gallery to show front, back, and placement references before the customer submits the order.</p>
      </div>

      <div class="shooting-shirt-section__meta-column">
        <div class="shooting-shirt-section__product-meta">
          <p class="shooting-shirt-section__eyebrow">Premium Team Practice Short Ordering</p>
          <h1 class="shooting-shirt-section__title">{{ product.title }}</h1>
          <p class="shooting-shirt-section__price">{{ display_price }}</p>
          <p class="shooting-shirt-section__intro">{{ section.settings.intro_copy }}</p>
          <ul class="shooting-shirt-section__feature-list">
            <li>100% polyester moisture-wicking mesh with lightweight 4oz fabric and an athletic fit.</li>
            <li>Standard 10in short with no pockets, sublimated in any color, and no additional setup fees.</li>
            <li>Final mockups and ship-date confirmation are emailed within 5 business days before the 30-day production window.</li>
          </ul>
        </div>

        <div class="shooting-shirt-section__summary-bar custom-practice-shorts-section__price-grid">
          <div class="shooting-shirt-section__summary-chip">
            <span class="shooting-shirt-section__summary-label">Mens</span>
            <span class="shooting-shirt-section__summary-value">$40.00 | XS-3XL</span>
          </div>
          <div class="shooting-shirt-section__summary-chip">
            <span class="shooting-shirt-section__summary-label">Womens</span>
            <span class="shooting-shirt-section__summary-value">$40.00 | XS-2XL</span>
          </div>
          <div class="shooting-shirt-section__summary-chip">
            <span class="shooting-shirt-section__summary-label">Youth</span>
            <span class="shooting-shirt-section__summary-value">$30.00 | YXS-YXL</span>
          </div>
          <div class="shooting-shirt-section__summary-chip">
            <span class="shooting-shirt-section__summary-label">Minimum</span>
            <span class="shooting-shirt-section__summary-value">{{ min_pieces }} Pieces</span>
          </div>
        </div>
      </div>

      <section class="shooting-shirt-section__panel shooting-shirt-section__panel--sizes">
        <div class="shooting-shirt-section__field-header">
          <span class="shooting-shirt-section__field-label">2. Size Breakdown</span>
          <span class="shooting-shirt-section__field-meta">Minimum {{ min_pieces }} total pieces</span>
        </div>

        <div class="shooting-shirt-section__sizes-grid custom-practice-shorts-section__sizes-grid">
          <div class="shooting-shirt-section__sizes-panel">
            <div class="shooting-shirt-section__sizes-panel-head">
              <span class="shooting-shirt-section__sizes-title">Mens</span>
              <span class="shooting-shirt-section__sizes-note">XS-3XL</span>
            </div>
            <div class="shooting-shirt-section__sizes-list">
              {% assign mens_sizes = 'XS,S,M,L,XL,2XL,3XL' | split: ',' %}
              {% for size in mens_sizes %}
                <label class="shooting-shirt-section__size-row">
                  <span class="shooting-shirt-section__size-name">{{ size }}</span>
                  <input
                    class="shooting-shirt-section__quantity-input"
                    type="number"
                    min="0"
                    max="99"
                    placeholder="0"
                    inputmode="numeric"
                    data-size-quantity
                    data-size-label="Mens {{ size }}"
                  >
                </label>
              {% endfor %}
            </div>
          </div>

          <div class="shooting-shirt-section__sizes-panel">
            <div class="shooting-shirt-section__sizes-panel-head">
              <span class="shooting-shirt-section__sizes-title">Womens</span>
              <span class="shooting-shirt-section__sizes-note">XS-2XL</span>
            </div>
            <div class="shooting-shirt-section__sizes-list">
              {% assign womens_sizes = 'XS,S,M,L,XL,2XL' | split: ',' %}
              {% for size in womens_sizes %}
                <label class="shooting-shirt-section__size-row">
                  <span class="shooting-shirt-section__size-name">{{ size }}</span>
                  <input
                    class="shooting-shirt-section__quantity-input"
                    type="number"
                    min="0"
                    max="99"
                    placeholder="0"
                    inputmode="numeric"
                    data-size-quantity
                    data-size-label="Womens {{ size }}"
                  >
                </label>
              {% endfor %}
            </div>
          </div>

          <div class="shooting-shirt-section__sizes-panel">
            <div class="shooting-shirt-section__sizes-panel-head">
              <span class="shooting-shirt-section__sizes-title">Youth</span>
              <span class="shooting-shirt-section__sizes-note">YXS-YXL</span>
            </div>
            <div class="shooting-shirt-section__sizes-list">
              {% assign youth_sizes = 'YXS,YS,YM,YL,YXL' | split: ',' %}
              {% for size in youth_sizes %}
                <label class="shooting-shirt-section__size-row">
                  <span class="shooting-shirt-section__size-name">{{ size }}</span>
                  <input
                    class="shooting-shirt-section__quantity-input"
                    type="number"
                    min="0"
                    max="99"
                    placeholder="0"
                    inputmode="numeric"
                    data-size-quantity
                    data-size-label="Youth {{ size }}"
                  >
                </label>
              {% endfor %}
            </div>
          </div>
        </div>
      </section>

      <section class="shooting-shirt-section__panel shooting-shirt-section__panel--colors">
        <div class="shooting-shirt-section__field-header">
          <span class="shooting-shirt-section__field-label">1. Colors</span>
          <button type="button" class="shooting-shirt-section__reset-link" data-reset-colors>Reset to default</button>
        </div>

        <div class="shooting-shirt-section__color-studio">
          <div class="shooting-shirt-section__color-topline">
            <div class="shooting-shirt-section__color-targets" role="tablist" aria-label="Color application">
              <button type="button" class="shooting-shirt-section__color-target is-active" data-color-target-button data-color-target="Base" data-color-apply-copy="Applies to the short body and waistband." aria-pressed="true">Short</button>
              <button type="button" class="shooting-shirt-section__color-target" data-color-target-button data-color-target="Artwork" data-color-apply-copy="Applies to logos, wording, and decoration placements." aria-pressed="false">Artwork + Decoration</button>
            </div>
            <p class="shooting-shirt-section__color-caption" data-active-color-display>#111111 (Black)</p>
          </div>

          <div class="shooting-shirt-section__color-layout">
            <label class="shooting-shirt-section__wheel-shell" aria-label="Choose practice short color">
              <span class="shooting-shirt-section__wheel-visual"></span>
              <input type="color" class="shooting-shirt-section__wheel-input" value="#111111" data-color-picker>
            </label>

            <div class="shooting-shirt-section__palette-area">
              <p class="shooting-shirt-section__color-apply" data-color-apply-copy>Applies to the short body and waistband.</p>

              <div class="shooting-shirt-section__swatch-group" data-color-group="Base">
                <p class="shooting-shirt-section__swatch-group-label">Recommended short colors</p>
                <div class="shooting-shirt-section__mini-swatches" role="list" aria-label="Recommended short colors">
                  {% for color_entry in short_colors %}
                    {% assign color_parts = color_entry | split: ':' %}
                    {% assign color_name = color_parts[0] %}
                    {% assign color_hex = color_parts[1] %}
                    <button
                      type="button"
                      class="shooting-shirt-section__mini-swatch{% if color_name == 'Black' %} is-active{% endif %}"
                      data-color-swatch
                      data-color-target-scope="Base"
                      data-color-name="{{ color_name }}"
                      data-color-value="{{ color_hex }}"
                      aria-label="{{ color_name }}"
                      aria-pressed="{% if color_name == 'Black' %}true{% else %}false{% endif %}"
                    >
                      <span class="shooting-shirt-section__mini-swatch-fill" style="background-color: {{ color_hex }};"></span>
                    </button>
                  {% endfor %}
                </div>
              </div>

              <div class="shooting-shirt-section__swatch-group" data-color-group="Artwork" hidden>
                <p class="shooting-shirt-section__swatch-group-label">Recommended artwork colors</p>
                <div class="shooting-shirt-section__mini-swatches" role="list" aria-label="Recommended artwork colors">
                  {% for color_entry in artwork_colors %}
                    {% assign color_parts = color_entry | split: ':' %}
                    {% assign color_name = color_parts[0] %}
                    {% assign color_hex = color_parts[1] %}
                    <button
                      type="button"
                      class="shooting-shirt-section__mini-swatch{% if color_name == 'White' %} is-active{% endif %}"
                      data-color-swatch
                      data-color-target-scope="Artwork"
                      data-color-name="{{ color_name }}"
                      data-color-value="{{ color_hex }}"
                      aria-label="{{ color_name }}"
                      aria-pressed="{% if color_name == 'White' %}true{% else %}false{% endif %}"
                    >
                      <span class="shooting-shirt-section__mini-swatch-fill" style="background-color: {{ color_hex }};"></span>
                    </button>
                  {% endfor %}
                </div>
              </div>

              <div class="shooting-shirt-section__hex-shell">
                <label class="shooting-shirt-section__field-label shooting-shirt-section__field-label--small" for="ColorHex-{{ section.id }}">Custom HEX</label>
                <div class="shooting-shirt-section__hex-row">
                  <span class="shooting-shirt-section__hex-preview" data-color-preview aria-hidden="true"></span>
                  <input
                    id="ColorHex-{{ section.id }}"
                    class="shooting-shirt-section__text-input"
                    type="text"
                    maxlength="7"
                    value="#111111"
                    autocomplete="off"
                    inputmode="text"
                    data-color-hex
                  >
                </div>
              </div>
            </div>
          </div>

          <div class="shooting-shirt-section__color-summary">
            <div class="shooting-shirt-section__color-summary-item" data-color-summary="Base">
              <span class="shooting-shirt-section__color-summary-label">Short</span>
              <span class="shooting-shirt-section__color-summary-value">#111111 (Black)</span>
            </div>
            <div class="shooting-shirt-section__color-summary-item" data-color-summary="Artwork">
              <span class="shooting-shirt-section__color-summary-label">Artwork</span>
              <span class="shooting-shirt-section__color-summary-value">#FFFFFF (White)</span>
            </div>
          </div>
        </div>
      </section>

      <section class="shooting-shirt-section__panel shooting-shirt-section__panel--upload">
        <div class="shooting-shirt-section__field-header">
          <span class="shooting-shirt-section__field-label">3. Artwork Upload</span>
          <span class="shooting-shirt-section__field-meta">SVG, AI, EPS only</span>
        </div>
        <div class="shooting-shirt-section__upload-copy">
          <p class="shooting-shirt-section__upload-headline">One production-ready vector file is required for the order.</p>
          <p class="shooting-shirt-section__upload-note">Final mockups and ship-date confirmation are emailed within 5 business days after the vector artwork is reviewed.</p>
        </div>
        <input
          class="shooting-shirt-section__file-input"
          type="file"
          name="properties[Artwork Upload]"
          accept=".svg,.ai,.eps"
          data-vector-upload
          required
        >
        <p class="shooting-shirt-section__upload-filename" data-upload-name>No file selected</p>
      </section>

      <section class="shooting-shirt-section__panel shooting-shirt-section__panel--notes">
        <div class="shooting-shirt-section__field-header">
          <label class="shooting-shirt-section__field-label" for="OrderNotes-{{ section.id }}">4. Order Notes</label>
          <span class="shooting-shirt-section__field-meta">Optional</span>
        </div>
        <textarea
          id="OrderNotes-{{ section.id }}"
          class="shooting-shirt-section__textarea"
          name="properties[Order Notes]"
          rows="6"
          placeholder="Add any production notes, placement notes, or ship-date context here."
        ></textarea>
      </section>

      <section class="shooting-shirt-section__panel shooting-shirt-section__panel--summary">
        <div class="shooting-shirt-section__field-header">
          <span class="shooting-shirt-section__field-label">Order Summary</span>
          <span class="shooting-shirt-section__field-meta">Saved with the order</span>
        </div>

        <div class="shooting-shirt-section__order-summary">
          <div class="shooting-shirt-section__order-summary-item">
            <span class="shooting-shirt-section__order-summary-label">Short Color</span>
            <span class="shooting-shirt-section__order-summary-value" data-summary-color="Base">#111111 (Black)</span>
          </div>
          <div class="shooting-shirt-section__order-summary-item">
            <span class="shooting-shirt-section__order-summary-label">Artwork Color</span>
            <span class="shooting-shirt-section__order-summary-value" data-summary-color="Artwork">#FFFFFF (White)</span>
          </div>
          <div class="shooting-shirt-section__order-summary-item">
            <span class="shooting-shirt-section__order-summary-label">Total Pieces</span>
            <span class="shooting-shirt-section__order-summary-value" data-summary-total-pieces>0 pieces</span>
          </div>
          <div class="shooting-shirt-section__order-summary-item custom-practice-shorts-section__order-summary-item--wide">
            <span class="shooting-shirt-section__order-summary-label">Size Breakdown</span>
            <span class="shooting-shirt-section__order-summary-value custom-practice-shorts-section__order-summary-value--wrap" data-summary-size-breakdown>No sizes entered yet</span>
          </div>
          <div class="shooting-shirt-section__order-summary-item">
            <span class="shooting-shirt-section__order-summary-label">Artwork Upload</span>
            <span class="shooting-shirt-section__order-summary-value custom-practice-shorts-section__order-summary-value--wrap" data-summary-upload-status>Not uploaded yet</span>
          </div>
        </div>
      </section>

      <div class="shooting-shirt-section__cta-section">
        <div class="shooting-shirt-section__cta-group">
          <button
            type="submit"
            class="shooting-shirt-section__cta shooting-shirt-section__cta--primary"
            data-add-to-cart
            data-submitting-label="Adding Practice Shorts Order..."
          >
            Add Practice Shorts Order To Cart
          </button>
          <a class="shooting-shirt-section__cta-link" href="/pages/contact?type=quote">Request Team Quote</a>
        </div>
      </div>

      <p class="shooting-shirt-section__rules">Minimum order: {{ min_pieces }} pieces. Short color, artwork color, size breakdown, notes, and vector artwork upload are submitted with the order for production review. No team logo add-on pricing is included on this page.</p>
    </form>
  </div>
</section>

{% schema %}
{
  "name": "Practice Shorts Order",
  "tag": "section",
  "class": "custom-practice-shorts-section",
  "settings": [
    { "type": "text", "id": "utility_bar_delivery", "label": "Delivery Time", "default": "Ready in 30 days" },
    { "type": "text", "id": "minimum_order", "label": "Minimum Order Text", "default": "6 pieces per order" },
    { "type": "url", "id": "contact_url", "label": "Contact Page URL" },
    { "type": "number", "id": "min_pieces", "label": "Minimum Pieces", "default": 6 },
    { "type": "textarea", "id": "intro_copy", "label": "Intro Copy", "default": "Build your practice short order with separate short and artwork colors, a full size breakdown, and one required vector artwork upload in the same streamlined Crossover Culture order flow." }
  ],
  "presets": [{ "name": "Practice Shorts Order" }]
}
{% endschema %}
